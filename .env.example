# Copy to .env on the self-hosted API server. Never commit real secrets.
APP_ENV=production
DATABASE_URL=postgresql://tbanastream:change-me@127.0.0.1:5432/tbanastream
SECRET_KEY=generate-a-random-value-with-at-least-32-characters
ACCESS_TOKEN_EXPIRE_MINUTES=43200
PUBLIC_BASE_URL=https://api.tbanastream.com
TRUSTED_HOSTS=api.tbanastream.com,127.0.0.1,localhost
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
LOG_LEVEL=info

APP_VERSION=1.0.8
UPDATE_REPOSITORY=shahred94/Tbana
TOYYIBPAY_BASE_URL=https://toyyibpay.com
TOYYIBPAY_CATEGORY_CODE=your-category-code
TOYYIBPAY_SECRET_KEY=your-secret-key
TOYYIBPAY_CALLBACK_URL=https://api.tbanastream.com/api/payment/callback
TOYYIBPAY_RETURN_URL=https://api.tbanastream.com/api/payment/return
PRO_PRICE_CENTS=2990
PRO_DURATION_DAYS=30
